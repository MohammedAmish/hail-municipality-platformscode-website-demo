{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "hail-municipality-website": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/hail-municipality-website",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "src/favicon.ico",
              "src/assets",
              "src/404.html"
            ],
            "styles": [
              "src/styles.scss"
            ],
            "scripts": [],
            "server": "src/main.server.ts",
            "prerender": false,
            "ssr": {
              "entry": "server.ts"
            },
            "allowedCommonJsDependencies": [
              "@grpc/grpc-js",
              "@grpc/proto-loader"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "5mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "5kb",
                  "maximumError": "5kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "hail-municipality-website:build:production"
            },
            "development": {
              "buildTarget": "hail-municipality-website:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "hail-municipality-website:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "src/favicon.ico",
              "src/assets",
              "src/404.html"
            ],
            "styles": [
              "src/styles.scss"
            ],
            "scripts": []
          }
        },
        "server": {
          "builder": "@angular-devkit/build-angular:server",
          "options": {
            "outputPath": "dist/hail-municipality-website-server",
            "main": "server.ts",
            "tsConfig": "tsconfig.server.json"
          },
          "configurations": {
            "production": {
              "outputHashing": "media",
              "sourceMap": false,
              "optimization": true
            }
          }
        },
        "prerender": {
          "builder": "@angular-devkit/build-angular:prerender",
          "options": {
            "browserTarget": "hail-municipality-website:build:production",
            "serverTarget": "hail-municipality-website:server:production",
            "routes": [
              "/",
              "/about-us",
              "/contact-us",
              "/faqs",
              "/statistics",
              "/search",
              "/social-media",
              "/e-participation",
              "/participation-policy",
              "/consultations",
              "/co-creation",
              "/open-data",
              "/complaints-suggestions",
              "/beneficiary",
              "/service",
              "/sitemap",
              "/page-not-found",
              "/princes",
              "/mayors",
              "/hail-area",
              "/geography",
              "/municipalities",
              "/guide",
              "/vision-mission",
              "/main-goals",
              "/internal-audit",
              "/mayor-profile",
              "/mayor-contact",
              "/executive-office",
              "/data-sharing",
              "/regulations",
              "/departments",
              "/organizational-structure",
              "/content",
              "/help-support"
            ]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "336d40fd-8a85-49bd-b499-4e1170cdc8a0"
  }
}
